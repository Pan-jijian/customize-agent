{
  "name": "customize-agent",
  "version": "1.0.1",
  "description": "通用终端 AI 助手 — 原生 Function Calling + 双语 TUI + 三级模型分层",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "bin": {
    "customize-agent": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "start": "node ./dist/index.js"
  },
  "license": "MIT",
  "author": "Pan-jijian",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pan-jijian/customize-agent.git",
    "directory": "apps/cli"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai-agent",
    "cli",
    "llm",
    "customize-agent",
    "terminal",
    "tui",
    "mcp"
  ],
  "packageManager": "pnpm@10.26.1",
  "dependencies": {
    "@customize-agent/engine": "workspace:*",
    "@customize-agent/llm": "workspace:*",
    "@customize-agent/memory": "workspace:*",
    "@customize-agent/runtime": "workspace:*",
    "@customize-agent/search": "workspace:*",
    "@customize-agent/tools": "workspace:*",
    "@customize-agent/types": "workspace:*",
    "@vscode/ripgrep": "^1.18.0",
    "commander": "^15.0.0",
    "fast-glob": "^3.3.3",
    "fd-find": "^1.2.0",
    "figlet": "^1.11.0",
    "marked": "^15.0.12",
    "string-width": "^8.2.1",
    "wrap-ansi": "^10.0.0"
  }
