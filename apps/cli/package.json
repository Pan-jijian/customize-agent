{
  "name": "customize-agent",
  "version": "2.1.2",
  "description": "通用终端 AI 助手 — 原生 Function Calling + 双语 TUI + 三级模型分层",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "customize": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && node scripts/bundle-server.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "start": "node ./dist/index.js"
  },
  "license": "MIT",
  "author": "Pan-jijian",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pan-jijian/customize-agent.git",
    "directory": "apps/cli"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai-agent",
    "cli",
    "llm",
    "customize-agent",
    "terminal",
    "tui",
    "mcp"
  ],
  "packageManager": "pnpm@10.26.1",
  "dependencies": {
    "@customize-agent/engine": "workspace:*",
    "@customize-agent/knowledge": "workspace:*",
    "@customize-agent/llm": "workspace:*",
    "@customize-agent/memory": "workspace:*",
    "@customize-agent/runtime": "workspace:*",
    "@customize-agent/search": "workspace:*",
    "@customize-agent/tools": "workspace:*",
    "@customize-agent/types": "workspace:*",
    "@napi-rs/canvas": "^0.1.82",
    "@vscode/ripgrep": "^1.18.0",
    "chromadb": "^3.0.18",
    "commander": "^15.0.0",
    "fast-glob": "^3.3.3",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "marked": "^15.0.12",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.4.394",
    "string-width": "^8.2.1",
    "tesseract.js": "^7.0.0",
    "wrap-ansi": "^10.0.0",
    "xlsx": "^0.18.5"
  }
}
