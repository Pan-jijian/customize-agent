{
  "name": "@customize-agent/server",
  "version": "4.0.1",
  "description": "Customize Agent Web 管理控制台",
  "exports": {
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "next dev -p 17321",
    "build": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true, maxRetries: 5, retryDelay: 200 })\" && next build && node scripts/verify-next-static.js && node -e \"require('fs').rmSync('.next/cache', { recursive: true, force: true, maxRetries: 5, retryDelay: 200 })\"",
    "prestart": "node scripts/verify-next-static.js",
    "start": "next start -p 17321",
    "lint": "eslint src/"
  },
  "files": [
    ".next/BUILD_ID",
    ".next/app-build-manifest.json",
    ".next/build-manifest.json",
    ".next/fallback-build-manifest.json",
    ".next/server",
    ".next/static",
    ".next/required-server-files.json",
    ".next/routes-manifest.json",
    ".next/prerender-manifest.json",
    ".next/images-manifest.json",
    ".next/react-loadable-manifest.json",
    "public",
    "next.config.ts",
    "postcss.config.mjs",
    "scripts",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "@napi-rs/canvas": "^0.1.82",
    "@customize-agent/knowledge": "workspace:^",
    "@customize-agent/llm": "workspace:^",
    "@customize-agent/runtime": "workspace:^",
    "antd": "^6.5.0",
    "better-sqlite3": "^12.10.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.400.0",
    "mammoth": "^1.12.0",
    "marked": "^15.0.12",
    "next": "^15.1.0",
    "next-themes": "^0.4.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.4.394",
    "playwright": "^1.57.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "^8.4.49",
    "sass": "^1.101.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  }
}
