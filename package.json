{
  "name": "customize-agent-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Customize Agent — 通用终端 AI 助手 Monorepo",
  "scripts": {
    "build": "turbo run build",
    "build:watch": "turbo run build --watch",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "doctor:hnsw": "node packages/knowledge/scripts/install-hnsw.cjs",
    "start:cli": "pnpm --filter customize-agent start",
    "check": "turbo run typecheck lint && vitest run",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release:version": "changeset version && pnpm install",
    "release:publish": "pnpm run release",
    "release": "pnpm run check && pnpm run build && changeset publish"
  },
  "keywords": [
    "ai-agent",
    "cli",
    "llm",
    "customize-agent",
    "terminal",
    "tui"
  ],
  "author": "Pan-jijian",
  "license": "MIT",
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "pnpm@10.26.1",
  "devDependencies": {
    "@changesets/cli": "^2.28.1",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.9",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "node-gyp": "^13.0.1",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.9"
  },
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pan-jijian/customize-agent.git"
  },
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Pan-jijian/customize-agent/issues"
  },
  "homepage": "https://github.com/Pan-jijian/customize-agent#readme",
  "pnpm": {
    "onlyBuiltDependencies": [
      "onnxruntime-node"
    ]
  }
}
